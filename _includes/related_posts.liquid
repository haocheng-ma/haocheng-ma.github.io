{% assign related_candidates = site.related_posts | where_exp: 'post', 'post.hidden != true' | where_exp: 'post', "post.lang != 'zh'" %}
{% if related_candidates != empty %}
  <br>
  <hr>
  <br>
  <h4>Enjoy Reading This Article?</h4>
  <p class="mb-2">Here are some more articles you might like to read next:</p>
  <ul>
    {% for post in related_candidates limit: site.related_blog_posts.max_related %}
      <li>
        <a href="{{ post.url | relative_url }}">{{ post.title }}</a>
      </li>
    {% endfor %}
  </ul>
  {% if site.newsletter.enabled and site.footer_fixed %}
    <p class="mb-2" style="margin-top: 1.5rem">Subscribe to be notified of future articles:</p>
    {% include scripts/newsletter.liquid left=true %}
  {% endif %}
{% endif %}
